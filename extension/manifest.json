{
  "manifest_version": 3,
  "name": "Moderator Template Helper",
  "version": "3.1.4",
  "description": "Helpt moderators lokaal een vraag- of antwoordtemplate te vullen vanuit het CRS-portaal.",
  "homepage_url": "https://github.com/m0nk111/template-helper/tree/chrome-store/compliance",
  "action": {
    "default_title": "Open Template Helper",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://crs.gw.dfnld.nl/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://crs.gw.dfnld.nl/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["template.html", "script.js"],
      "matches": [
        "https://crs.gw.dfnld.nl/*"
      ]
    }
  ]
}
