{
  "manifest_version": 3,
  "name": "Vraag & Antwoord Helper",
  "version": "1.0",
  "description": "Haalt met één klik gegevens uit het systeem en opent de Moderator Vraag & Antwoord Template.",
  "action": {
    "default_title": "Open Vraag Template"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["template.html"],
      "matches": ["<all_urls>"]
    }
  ]
}